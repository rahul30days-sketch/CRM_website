{
  "name": "ezcrm-website",
  "version": "1.0.0",
  "private": true,
  "description": "EZCRM 3.0 marketing website — Next.js 15 + Payload CMS",
  "type": "module",
  "engines": {
    "node": ">=18.20.2"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "typecheck": "tsc --noEmit",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation payload run src/seed/index.ts",
    "payload": "payload"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "^3.44.0",
    "@payloadcms/next": "^3.44.0",
    "@payloadcms/richtext-lexical": "^3.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.16.0",
    "lucide-react": "^0.515.0",
    "next": "~15.4.11",
    "next-themes": "^0.4.6",
    "payload": "^3.44.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sharp": "^0.34.2",
    "tailwind-merge": "^3.3.0",
    "validator": "^13.15.15",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/validator": "^13.15.1",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
