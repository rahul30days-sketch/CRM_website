# ── EZCRM website environment ────────────────────────────────────────────────
# Copy to .env for local development. Real values NEVER enter the repo —
# in production, inject these through your host's secret manager.
# Nothing here may be renamed to NEXT_PUBLIC_* except NEXT_PUBLIC_SITE_URL,
# which is a public, non-secret value by design.

# MongoDB Atlas connection string (Database → Connect → Drivers)
DATABASE_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/ezcrm-site

# Payload encryption/signing secret — at least 32 chars.
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace-me-with-64-hex-chars-from-openssl-rand

# Canonical site origin (no trailing slash). Used for CORS/CSRF allowlists,
# canonical URLs, sitemap and OG tags.
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — shared secret for the Payload → Next.js revalidation webhook
# Generate with: openssl rand -hex 16
#REVALIDATION_SECRET=

# Optional — transactional mail (demo-request notifications)
#SMTP_HOST=
#SMTP_USER=
#SMTP_PASS=
